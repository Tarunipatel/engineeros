# Local development (default, no setup needed):
DATABASE_URL=file:./db/engineeros.db

# Production (Turso) — set these in your Vercel project's Environment Variables:
# DATABASE_URL=libsql://<your-db-name>-<your-org>.turso.io
# DATABASE_AUTH_TOKEN=<token from `turso db tokens create <your-db-name>`>

# The app is single-user and pins all "today"/streak/date logic to this
# timezone regardless of what timezone the server process runs in (Vercel
# serverless functions default to UTC). Defaults to Asia/Kolkata if unset.
# APP_TIMEZONE=Asia/Kolkata
